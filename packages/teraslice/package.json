{
    "name": "teraslice",
    "displayName": "Teraslice",
    "version": "3.13.0",
    "description": "Distributed computing platform for processing JSON data",
    "homepage": "https://github.com/terascope/teraslice#readme",
    "bugs": {
        "url": "https://github.com/terascope/teraslice/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/terascope/teraslice.git"
    },
    "license": "Apache-2.0",
    "author": "Terascope, LLC <info@terascope.io>",
    "type": "module",
    "main": "dist/src/index.js",
    "typings": "dist/src/index.d.ts",
    "files": [
        "*.js",
        "lib/**/*",
        "examples/**/*"
    ],
    "scripts": {
        "build": "tsc --build",
        "build:watch": "pnpm build --watch",
        "start": "node service.js",
        "test": "TEST_OPENSEARCH='true' node ../scripts/bin/ts-scripts test ../teraslice --",
        "test:debug": "TEST_OPENSEARCH='true' node ../scripts/bin/ts-scripts test --debug ../teraslice --",
        "test:opensearch1": "TEST_OPENSEARCH='true' OPENSEARCH_VERSION='1.3.11' node ../scripts/bin/ts-scripts test ../teraslice --",
        "test:opensearch2": "TEST_OPENSEARCH='true' OPENSEARCH_VERSION='2.15.0' node ../scripts/bin/ts-scripts test ../teraslice --",
        "test:opensearch3": "TEST_OPENSEARCH='true' OPENSEARCH_VERSION='3.1.0' node ../scripts/bin/ts-scripts test ../teraslice --",
        "test:watch": "TEST_OPENSEARCH='true' node ../scripts/bin/ts-scripts test --watch ../teraslice --"
    },
    "dependencies": {
        "@kubernetes/client-node": "~1.4.0",
        "@terascope/core-utils": "workspace:~",
        "@terascope/data-types": "workspace:~",
        "@terascope/elasticsearch-api": "workspace:~",
        "@terascope/file-asset-apis": "~2.1.1",
        "@terascope/job-components": "workspace:~",
        "@terascope/teraslice-messaging": "workspace:~",
        "@terascope/types": "workspace:~",
        "@terascope/valkey": "workspace:~",
        "async-mutex": "~0.5.0",
        "barbe": "~3.0.17",
        "body-parser": "~2.3.0",
        "decompress": "~4.2.1",
        "easy-table": "~1.2.0",
        "express": "~5.2.1",
        "fs-extra": "~11.3.5",
        "get-port": "~7.2.0",
        "got": "~15.0.6",
        "ip": "~2.0.1",
        "ms": "~2.1.3",
        "nanoid": "~5.1.15",
        "semver": "~7.8.5",
        "socket.io": "~4.8.3",
        "socket.io-client": "~4.8.3",
        "terafoundation": "workspace:~",
        "terafoundation_kafka_connector": "~2.4.0",
        "uuid": "~14.0.1"
    },
    "devDependencies": {
        "@jest/globals": "^30.4.1",
        "@terascope/opensearch-client": "workspace:~",
        "@terascope/scripts": "workspace:~",
        "@types/archiver": "~8.0.0",
        "@types/body-parser": "~1.19.6",
        "@types/decompress": "~4.2.7",
        "@types/express": "~5.0.6",
        "@types/ip": "~1.1.3",
        "@types/js-yaml": "~4.0.9",
        "@types/ms": "~0.7.34",
        "@types/semver": "~7.7.1",
        "archiver": "~8.0.0",
        "bufferstreams": "~6.0.1",
        "chance": "~1.1.13",
        "jest-extended": "~7.0.0",
        "jest-fixtures": "~0.6.0",
        "js-yaml": "~5.0.0",
        "nock": "~14.0.15"
    },
    "engines": {
        "node": ">=22.0.0",
        "pnpm": ">=11.3.0"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "terascope": {
        "main": true,
        "enableTypedoc": false,
        "testSuite": "opensearch"
    }
}
